{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(cat *)",
      "Bash(cat > **/.kiro/specs/*/spec.json)",
      "Bash(claude --help)",
      "Bash(claude --version)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh --version)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(gh release *)",
      "Bash(gh search *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git config *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git merge *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git worktree *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(make *)",
      "Bash(mkdir -p *)",
      "Bash(npx *)",
      "Bash(pre-commit run *)",
      "Bash(pytest *)",
      "Bash(python3 *)",
      "Bash(ruff *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(uname *)",
      "Bash(uv *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Edit(*.json)",
      "Edit(*.md)",
      "Edit(*.py)",
      "Edit(*.sh)",
      "Edit(*.toml)",
      "Edit(*.yaml)",
      "Edit(*.yml)",
      "Read",
      "Skill",
      "WebSearch",
      "Write(tmp/**)",
      "mcp__ide__getDiagnostics"
    ],
    "additionalDirectories": [".claude/worktrees"],
    "deny": [
      "Bash(cat **/.env*)",
      "Bash(cat **/secrets/*)",
      "Bash(cat *credential*)",
      "Bash(cat *token*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.config/gcloud/*)",
      "Bash(cat ~/.docker/*)",
      "Bash(cat ~/.kube/*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(env)",
      "Bash(gcloud auth *)",
      "Bash(gh pr merge *)",
      "Bash(git commit *--no-verify*)",
      "Bash(git commit *-n *)",
      "Bash(printenv)",
      "Bash(set)",
      "Read(**/.env*)",
      "Read(**/*credential*)",
      "Read(**/*token*)",
      "Read(**/secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.docker/**)",
      "Read(~/.kube/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-context-injector/skill-context-injector.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-format.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-write-html-host-path.sh"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-context-injector/skill-context-injector.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/notify-sound.sh start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/notify-sound.sh stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/notify-sound.sh notify"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": false
  },
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh"
  }
}
