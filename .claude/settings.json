{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "WebSearch",
      "Read",
      "Skill",
      "mcp__ide__getDiagnostics",
      "Edit(*.md)",
      "Edit(*.py)",
      "Edit(*.json)",
      "Edit(*.yaml)",
      "Edit(*.yml)",
      "Edit(*.toml)",
      "Edit(*.sh)",
      "Write(tmp/**)",
      "Bash(touch *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir -p *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(sort *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git config *)",
      "Bash(git worktree *)",
      "Bash(pytest *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(pre-commit run *)",
      "Bash(npx *)",
      "Bash(python3 *)",
      "Bash(make *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh release *)",
      "Bash(uname *)",
      "Bash(claude --version)",
      "Bash(claude --help)",
      "Bash(cat > **/.kiro/specs/*/spec.json)"
    ],
    "additionalDirectories": [".claude/worktrees"],
    "ask": [
      "Edit(**/settings.json)",
      "Edit(**/settings.local.json)",
      "Write(**/settings.json)",
      "Write(**/settings.local.json)",
      "Bash(git push *)",
      "Bash(* install *)",
      "Bash(* uninstall *)"
    ],
    "deny": [
      "Read(~/.config/gcloud/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.docker/**)",
      "Read(~/.kube/**)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*credential*)",
      "Read(**/*token*)",
      "Bash(gcloud auth *)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(set)",
      "Bash(cat ~/.config/gcloud/*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.docker/*)",
      "Bash(cat ~/.kube/*)",
      "Bash(cat *credential*)",
      "Bash(cat *token*)",
      "Bash(cat **/.env*)",
      "Bash(cat **/secrets/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-context-injector/skill-context-injector.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-format.sh"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-context-injector/skill-context-injector.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": false
  },
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh"
  }
}
